# ============================================================
# GPUSniff backend configuration
# Copy to .env and fill in the keys you have. Any provider
# whose keys are missing is skipped and its retailers fall
# back to cached/estimated data, so the server runs fine
# with zero keys during development.
# ============================================================

# --- Server ---
# Railway (and most PaaS) set PORT automatically; 3000 is the local default.
PORT=3000
# Comma-separated extra origins allowed to call the API.
# https://gpusniff.com and https://www.gpusniff.com are ALWAYS allowed,
# and any chrome-extension:// / moz-extension:// origin is allowed too,
# so you usually don't need to set this. (ALLOWED_ORIGINS is a legacy alias.)
CORS_ORIGIN=
# NOTE: Prices are always real. Mock/stand-in data runs ONLY when zero
# providers below are configured (pure local dev). As soon as any one
# provider has credentials, only real prices are returned.

# --- Best Buy Product API (key pending) ---
# https://developer.bestbuy.com/  — used directly for Best Buy SKUs.
BESTBUY_API_KEY=

# --- CJ Affiliate (GraphQL) — Best Buy + B&H Photo product feeds ---
# https://developers.cj.com/graphql
CJ_PERSONAL_ACCESS_TOKEN=
CJ_COMPANY_ID=
# Advertiser IDs (CJ) for the retailers you're joined with, comma-separated.
CJ_ADVERTISER_IDS=

# --- eBay Browse API ---
# https://developer.ebay.com/api-docs/buy/browse/overview.html
# Provide an OAuth application (client-credentials) token, OR the
# client id/secret and the server will mint + refresh the token itself.
EBAY_OAUTH_TOKEN=
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_CAMPAIGN_ID=
# SANDBOX or PRODUCTION
EBAY_ENV=PRODUCTION

# --- Walmart (Impact Radius affiliate) ---
# https://impact.com/  — Walmart product catalog + tracking.
IMPACT_ACCOUNT_SID=
IMPACT_AUTH_TOKEN=
IMPACT_WALMART_CAMPAIGN_ID=

# --- Rakuten Advertising (LinkShare) — Newegg product feed ---
# https://developers.rakutenadvertising.com/  — Product Search API.
# All four must be set for the provider to activate. Auth is a two-step
# OAuth2 exchange: Basic base64(RAKUTEN_TOKEN:RAKUTEN_SECURITY_TOKEN) at
# /token → access token → Bearer on Product Search.
# RAKUTEN_TOKEN:          web-services token (client id for the exchange).
# RAKUTEN_SECURITY_TOKEN: security token (client secret for the exchange).
# RAKUTEN_SID:            site/publisher id, used to build affiliate deep links.
# RAKUTEN_NEWEGG_MID:     Newegg's merchant id on Rakuten (44583) — scopes the search.
RAKUTEN_TOKEN=
RAKUTEN_SECURITY_TOKEN=
RAKUTEN_SID=
RAKUTEN_NEWEGG_MID=44583

# --- Supabase (price history + waitlist) ---
# https://app.supabase.com  →  Project Settings → API
SUPABASE_URL=
# Use the SERVICE ROLE key (server-side only — never ship in the extension).
SUPABASE_SERVICE_ROLE_KEY=

# --- Caching ---
# How long (seconds) aggregated prices are cached in memory.
PRICE_CACHE_TTL_SECONDS=900
